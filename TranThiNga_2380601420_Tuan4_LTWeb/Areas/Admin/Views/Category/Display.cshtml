@model TranThiNga_2380601420_Tuan4_LTWeb.Models.Category

@{
    ViewData["Title"] = "Category Details";
}

<h2 class="mb-4">Chi tiết danh mục</h2>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Tên danh mục</dt>
    <dd class="col-sm-10">@Model.Name</dd>
</dl>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary">← Quay lại</a>
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning text-white">Chỉnh sửa</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Xóa</a>
</div>
