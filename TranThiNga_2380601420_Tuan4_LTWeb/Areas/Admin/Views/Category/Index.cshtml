@model IEnumerable<TranThiNga_2380601420_Tuan4_LTWeb.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-4">Quản lý danh mục</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div></div>
    <a asp-action="Add" class="btn btn-primary">Thêm danh mục</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th scope="col">Id</th>
                <th scope="col">Tên danh mục</th>
                <th scope="col">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Id</td>
                    <td>@category.Name</td>
                    <td>
                        <a asp-action="Display" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary me-1">Xem</a>
                        <a asp-action="Update" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary me-1">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
