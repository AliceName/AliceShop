@model IEnumerable<TranThiNga_2380601420_Tuan4_LTWeb.Models.Product>

<h2 class="mb-4">Sản phẩm</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div></div>
    <a asp-action="Add" class="btn btn-primary">Thêm sản phẩm</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th scope="col">Ảnh</th>
                <th scope="col">Tên sản phẩm</th>
                <th scope="col">Giá</th>
                <th scope="col">Mô tả sản phẩm</th>
                <th scope="col">Phân loại</th>
                <th scope="col">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                // Choose first non-empty image URL from Images, otherwise ImageUrl, otherwise placeholder
                var firstImage = product.Images?.FirstOrDefault(i => !string.IsNullOrWhiteSpace(i.Url))?.Url
                ?? product.ImageUrl;
                // Normalize to ensure URL is relative to web root (starts with "/")
                if (!string.IsNullOrWhiteSpace(firstImage) && !firstImage.StartsWith("/"))
                {
                    firstImage = "/" + firstImage;
                }
                var imgUrl = !string.IsNullOrWhiteSpace(firstImage) ? firstImage : "/images/placeholder.png";

                <tr>
                    <td style="width:110px;">
                        <a asp-action="Display" asp-route-id="@product.Id" title="View">
                            <img src="@imgUrl" alt="@product.Name" class="img-thumbnail" style="width:96px;height:72px;object-fit:cover;">
                        </a>
                    </td>
                    <td>@product.Name</td>
                    <td>@product.Price.ToString("N0")₫</td>
                    <td class="text-truncate" style="max-width:300px;">@product.Description</td>
                    <td>@(product.Category?.Name ?? "No Category")</td>
                    <td>
                        <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary me-1">Xem</a>
                        <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-sm btn-outline-secondary me-1">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>