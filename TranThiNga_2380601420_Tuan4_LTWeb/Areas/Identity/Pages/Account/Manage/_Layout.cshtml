@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="mb-0 fs-4"><i class="bi bi-person-circle me-2"></i>Quản lý tài khoản</h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <h4 class="card-title text-muted mb-4 pb-2 border-bottom">Thay đổi cài đặt tài khoản của bạn</h4>
                    <div class="row">
                        <div class="col-md-4 col-lg-3 mb-4 mb-md-0">
                            <!-- Gọi partial mặc định của Identity để hiển thị menu bên trái -->
                            <partial name="_ManageNav" />
                        </div>
                        <div class="col-md-8 col-lg-9 ps-md-4">
                            @RenderBody()
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
