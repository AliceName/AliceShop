@inject SignInManager<ApplicationUser> SignInManager
@using TranThiNga_2380601420_Tuan4_LTWeb.Models
@using Microsoft.AspNetCore.Identity

@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    var currentPath = ViewContext.HttpContext.Request.Path.Value.ToLower();
}
<ul class="nav nav-pills flex-column gap-2">
    <li class="nav-item">
        <a class="nav-link @(currentPath.EndsWith("/manage") || currentPath.EndsWith("/manage/index") ? "active" : "")" asp-page="./Index">
            <i class="bi bi-person me-2"></i>Hồ sơ
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentPath.EndsWith("/email") ? "active" : "")" asp-page="./Email">
            <i class="bi bi-envelope me-2"></i>Email
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentPath.EndsWith("/changepassword") ? "active" : "")" asp-page="./ChangePassword">
            <i class="bi bi-key me-2"></i>Mật khẩu
        </a>
    </li>
    @if (hasExternalLogins)
    {
        <li class="nav-item">
            <a class="nav-link @(currentPath.EndsWith("/externallogins") ? "active" : "")" asp-page="./ExternalLogins">
                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngoài
            </a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link @(currentPath.EndsWith("/twofactorauthentication") ? "active" : "")" asp-page="./TwoFactorAuthentication">
            <i class="bi bi-shield-lock me-2"></i>Xác thực 2 yếu tố
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentPath.EndsWith("/personaldata") ? "active" : "")" asp-page="./PersonalData">
            <i class="bi bi-database-down me-2"></i>Dữ liệu cá nhân
        </a>
    </li>
</ul>
