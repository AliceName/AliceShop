@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Xác nhận quên mật khẩu";
}

<div class="d-flex justify-content-center align-items-center py-5">
    <div class="card shadow-sm border-0 overflow-hidden" style="max-width:500px; width:100%;">
        <div class="card-body p-4 p-md-5 text-center">
            <div class="mb-4">
                <i class="bi bi-envelope-check text-success" style="font-size: 4rem;"></i>
            </div>
            <h3 class="mb-3 fw-bold text-dark">Kiểm tra email của bạn</h3>
            <p class="text-muted mb-4">
                Vui lòng kiểm tra email của bạn để đặt lại mật khẩu. Nếu bạn không thấy email trong hộp thư đến, hãy kiểm tra thư mục thư rác (spam).
            </p>
            
            <a asp-page="./Login" class="btn btn-dark btn-lg w-100 rounded-pill">Quay lại đăng nhập</a>
        </div>
    </div>
</div>
