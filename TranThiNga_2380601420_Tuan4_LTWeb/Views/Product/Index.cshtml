@model IEnumerable<TranThiNga_2380601420_Tuan4_LTWeb.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm";
    var search = ViewBag.Search as string;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                <h4 class="m-0 text-uppercase fw-bold">
                    @if (!string.IsNullOrWhiteSpace(search))
                    {
                        <text>Kết quả tìm kiếm: "@search"</text>
                    }
                    else
                    {
                        <text>Tất cả sản phẩm</text>
                    }
                </h4>
            </div>

            @if (Model.Any())
            {
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @foreach (var item in Model)
                    {
                        <partial name="_ProductCard" model="item" />
                    }
                </div>
            }
            else
            {
                <p class="text-muted">Không tìm thấy sản phẩm phù hợp.</p>
            }
        </div>

        <div class="col-md-3">
            <partial name="_SocialSidebar" />
        </div>
    </div>
</div>
