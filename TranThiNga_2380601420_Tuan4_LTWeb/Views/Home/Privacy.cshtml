@{
    ViewData["Title"] = "Chính sách bảo mật";
}

<div class="container mt-5 mb-5">
    <div class="col-lg-8">
        <h2 class="text-uppercase fw-bold border-bottom pb-3 mb-4">@ViewData["Title"]</h2>
        <p class="text-muted">
            ALICE STORE cam kết bảo mật thông tin cá nhân của khách hàng. Dữ liệu đăng ký, đơn hàng và thanh toán
            chỉ được sử dụng để xử lý giao dịch và hỗ trợ khách hàng.
        </p>
        <p class="text-muted mb-0">
            Mọi thắc mắc vui lòng liên hệ qua trang <a asp-action="Contact">Liên hệ</a>.
        </p>
    </div>
</div>
