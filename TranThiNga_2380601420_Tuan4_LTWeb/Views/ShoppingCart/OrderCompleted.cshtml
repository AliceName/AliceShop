@model int

@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<section class="py-5">
    <div class="container">
        <div class="col-lg-6 mx-auto text-center">
            <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-4"
                 style="width: 88px; height: 88px;">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
            </div>
            <h2 class="fw-bold mb-2">Cảm ơn bạn đã đặt hàng!</h2>
            <p class="text-muted mb-1">Mã đơn hàng: <strong class="text-dark">#@Model.ToString("D6")</strong></p>
            <p class="text-muted mb-4">
                Chúng tôi sẽ liên hệ xác nhận và giao hàng trong thời gian sớm nhất.
            </p>
            @if (TempData["OrderMessage"] is string orderMsg)
            {
                <div class="alert alert-success small mb-4">@orderMsg</div>
            }
            <div class="d-flex flex-wrap justify-content-center gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-warning text-dark fw-semibold">
                    Tiếp tục mua sắm
                </a>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">
                    Xem sản phẩm
                </a>
                <a asp-controller="ShoppingCart" asp-action="Index" class="btn btn-outline-dark">
                    Xem giỏ hàng
                </a>
            </div>
        </div>
    </div>
</section>
